set_global_assignment -name IP_TOOL_NAME "FIFO"
set_global_assignment -name IP_TOOL_VERSION "25.1"
set_global_assignment -name IP_GENERATED_DEVICE_FAMILY "{MAX 10}"
set_global_assignment -name VHDL_FILE [file join $::quartus(qip_path) "fifo_128.vhd"]
set_global_assignment -name MISC_FILE [file join $::quartus(qip_path) "fifo_128.bsf"]
set_global_assignment -name MISC_FILE [file join $::quartus(qip_path) "fifo_128_inst.vhd"]
set_global_assignment -name MISC_FILE [file join $::quartus(qip_path) "fifo_128.cmp"]
